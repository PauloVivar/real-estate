{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "all-services",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "postgres",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "postgres"],
      "port": 5432,
      "autoPort": false
    },
    {
      "name": "backend",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build", "backend"],
      "port": 8000,
      "autoPort": false
    },
    {
      "name": "video",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build", "video"],
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "frontend",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build", "frontend"],
      "port": 3000,
      "autoPort": false
    }
  ]
}
